&НаКлиенте
Процедура ВводЧислаПриИзменении(Элемент)
    
    Если Объект.ВводЧисла < 2 ИЛИ Объект.ВводЧисла > 5 Тогда
        Сообщить("Ошибка: число должно быть от 2 до 5");
        Возврат;
    КонецЕсли;
    
    Размер = Объект.ВводЧисла;    
    
    Матрица = Новый Массив(Размер, Размер);
    ГЧС = Новый ГенераторСлучайныхЧисел();
    
    Для Строка = 0 По Размер - 1 Цикл
        Для Колонка = 0 По Размер - 1 Цикл
            Матрица[Строка][Колонка] = ГЧС.СлучайноеЧисло(1, 9);
        КонецЦикла;
    КонецЦикла;
    
    // Выводим только матрицу
    Для Строка = 0 По Размер - 1 Цикл
        СтрокаДляВывода = "";
        Для Колонка = 0 По Размер - 1 Цикл
            СтрокаДляВывода = СтрокаДляВывода + Формат(Матрица[Строка][Колонка], "ЧГ=0") + "  ";
        КонецЦикла;
        Сообщить(СтрокаДляВывода);
    КонецЦикла;
    
    СуммаЧетных = 0;
    Для Индекс = 0 По Размер * Размер - 1 Цикл
        Строка = Индекс / Размер;
        Колонка = Индекс % Размер;
        Элемент = Матрица[Строка][Колонка];
        
        Если Индекс % 2 = 0 И Элемент % 2 = 0 Тогда
            СуммаЧетных = СуммаЧетных + Элемент;
        КонецЕсли;
    КонецЦикла;
    
    Сообщить("Сумма четных элементов с четными индексами: " + СуммаЧетных);
    
КонецПроцедуры
